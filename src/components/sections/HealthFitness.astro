---
import { User, Scale, Flame, Heart, Activity, Target, Pencil, CheckCircle, TrendingUp } from 'lucide-react';
import type { ComponentType } from 'react';

// Sample user: Age 26, Weight 72 kg, Height 175 cm, Male
// BMI = 72 / 1.75^2 = 23.5  →  Healthy
// BMR (Mifflin-St Jeor) = 10*72 + 6.25*175 - 5*26 + 5 = 1689 kcal/day
// Max HR (Tanaka)       = 208 - 0.7 * 26 = 190 bpm
// TDEE (mod. active)    = 1689 * 1.55 = 2618 kcal/day

// Gauge: display range 16–36 BMI
// Segment boundaries: Under < 18.5, Healthy 18.5–24.9, Over 25–29.9, Obese 30+
// In 16–36 range:  (18.5-16)/20=12.5%  (24.9-16)/20=44.5%  (29.9-16)/20=69.5%
// Marker at 23.5:  (23.5-16)/20 = 37.5%

const metrics = [
  { Icon: Flame,    label: 'At Rest',  value: '1,689', unit: 'kcal/day', sublabel: 'BMR',        color: '#FF6B00' },
  { Icon: Heart,    label: 'Max HR',   value: '190',   unit: 'bpm',      sublabel: 'Tanaka',      color: '#FF0080' },
  { Icon: Activity, label: 'Activity', value: '2,847', unit: 'kcal',     sublabel: 'Total burn',  color: '#AAFF00' },
] satisfies { Icon: ComponentType<any>; label: string; value: string; unit: string; sublabel: string; color: string }[];

const goalChips = [
  { label: 'Lose weight', kcal: '−400 kcal', active: false, color: '#f59e0b' },
  { label: 'Maintain',    kcal: '',           active: true,  color: '#22c55e' },
  { label: 'Build muscle',kcal: '+250 kcal',  active: false, color: '#8b5cf6' },
];

const measurements = [
  { label: 'Age',    value: '26',  unit: 'yrs' },
  { label: 'Weight', value: '72',  unit: 'kg'  },
  { label: 'Height', value: '175', unit: 'cm'  },
  { label: 'Gender', value: 'M',   unit: ''    },
];

const benefits = [
  { Icon: Scale,     color: '#AAFF00', title: 'BMI at a Glance',          desc: 'Color-coded BMI gauge with Underweight / Healthy / Overweight / Obese labels, always synced to your latest weight.' },
  { Icon: Flame,     color: '#FF6B00', title: 'Science-backed Calories',   desc: 'BMR via Mifflin–St Jeor. TDEE adjusted for your actual activity level — not generic daily averages.' },
  { Icon: Heart,     color: '#FF0080', title: 'Personal Heart Rate Zone',  desc: 'Tanaka formula gives your individual max HR ceiling so every run stays in the right intensity zone.' },
  { Icon: Target,    color: '#00D4FF', title: 'Goal-aware Daily Plan',     desc: 'BMI-informed goal chips let you switch between Lose, Maintain, or Build muscle with one tap.' },
] satisfies { Icon: ComponentType<any>; color: string; title: string; desc: string }[];
---

<section class="relative py-24 lg:py-32 overflow-hidden">
  <div class="absolute inset-0 dark:bg-dark-900 bg-light-100"></div>
  <div class="absolute inset-0 grid-overlay opacity-20"></div>
  <div class="absolute top-1/3 right-0 w-[600px] h-[600px] bg-neon-lime/5 rounded-full blur-[140px]"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-neon-pink/5 rounded-full blur-[120px]"></div>

  <div class="relative section-padding">
    <div class="section-container">

      <!-- Header -->
      <div class="text-center mb-20 reveal">
        <span class="badge-lime mb-4">Health & Fitness</span>
        <h2 class="font-display font-black text-4xl sm:text-5xl lg:text-6xl dark:text-white text-dark-950 mt-4 mb-6">
          Real Numbers.<br/>
          <span class="gradient-text-lime">Real Science.</span>
        </h2>
        <p class="dark:text-white/50 text-dark-500 text-lg max-w-xl mx-auto">
          ClaimX isn't just a game. It's a full health dashboard that tracks your BMI, calories, and
          heart rate — powered by clinical formulas, not guesswork.
        </p>
      </div>

      <!-- Two-column layout -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        <!-- ── LEFT: Health Profile mockup ── -->
        <div class="reveal-left">
          <div class="glass rounded-3xl p-5 holographic relative">

            <!-- Sample UI badge -->
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 z-10">
              <span class="badge-blue text-[10px] font-mono tracking-wider px-3 py-1">Sample UI</span>
            </div>

            <!-- Card header -->
            <div class="flex items-center justify-between mb-5">
              <div class="flex items-center gap-2">
                <User class="w-4 h-4 text-neon-lime flex-none" />
                <span class="font-display font-bold dark:text-white text-dark-900 text-sm tracking-wide">Health Profile</span>
              </div>
              <button class="flex items-center gap-1.5 glass px-2.5 py-1 rounded-lg text-[10px] font-mono dark:text-white/40 text-dark-400 hover:dark:text-white/70 transition-colors">
                <Pencil class="w-2.5 h-2.5" />
                Edit
              </button>
            </div>

            <!-- ── BMI ── -->
            <div class="mb-5">
              <div class="flex items-end justify-between mb-2.5">
                <div class="flex items-baseline gap-2">
                  <span class="font-display font-black text-4xl dark:text-white text-dark-900">23.5</span>
                  <span class="text-xs dark:text-white/40 text-dark-400 font-mono">BMI</span>
                </div>
                <span class="text-[11px] font-black tracking-widest px-3 py-1 rounded-full"
                  style="background: rgba(34,197,94,0.18); color: #22c55e; border: 1px solid rgba(34,197,94,0.35);">
                  ● Healthy
                </span>
              </div>

              <!-- Gauge bar -->
              <div class="relative h-3 rounded-full overflow-hidden mb-1.5"
                style="background: linear-gradient(to right, #60a5fa 0% 12.5%, #22c55e 12.5% 44.5%, #f59e0b 44.5% 69.5%, #ef4444 69.5% 100%);">
                <!-- Marker -->
                <div class="absolute top-0 h-full w-[3px] bg-white rounded-full"
                  style="left: 37.5%; transform: translateX(-50%); box-shadow: 0 0 6px rgba(255,255,255,0.9);"></div>
              </div>

              <!-- Gauge labels -->
              <div class="grid grid-cols-4 text-[8px] font-mono mb-2.5" style="color: rgba(255,255,255,0.25);">
                <span>Underweight</span>
                <span class="text-center" style="color: #22c55e;">Healthy</span>
                <span class="text-center">Overweight</span>
                <span class="text-right">Obese</span>
              </div>

              <!-- Ideal weight -->
              <div class="flex items-center gap-2 text-[10px]">
                <span class="dark:text-white/35 text-dark-400">Ideal weight range</span>
                <span class="font-mono font-semibold dark:text-white/70 text-dark-700">56.6 – 76.2 kg</span>
              </div>
            </div>

            <!-- ── Measurements grid ── -->
            <div class="grid grid-cols-4 gap-2 mb-5">
              {measurements.map((m) => (
                <div
                  class="rounded-xl p-2.5 text-center"
                  style={{ background: 'rgba(255,255,255,0.04)', border: '1px solid rgba(255,255,255,0.08)' }}
                >
                  <div class="text-[8px] font-mono dark:text-white/30 text-dark-400 mb-1">{m.label}</div>
                  <div class="font-display font-black text-base dark:text-white text-dark-900 leading-none">{m.value}</div>
                  {m.unit && <div class="text-[8px] dark:text-white/30 text-dark-400 mt-0.5">{m.unit}</div>}
                </div>
              ))}
            </div>

            <!-- ── 3 metric cards ── -->
            <div class="grid grid-cols-3 gap-2 mb-4">
              {metrics.map((m) => {
                const Icon = m.Icon;
                return (
                  <div
                    class="rounded-xl p-3"
                    style={{ background: `${m.color}0D`, border: `1px solid ${m.color}25` }}
                  >
                    <div class="flex items-center gap-1.5 mb-2">
                      <Icon class="w-3 h-3 flex-none" style={{ color: m.color }} />
                      <span class="text-[8px] font-mono dark:text-white/35 text-dark-400">{m.label}</span>
                    </div>
                    <div class="flex items-baseline gap-1 flex-wrap">
                      <span class="font-display font-black text-base dark:text-white text-dark-900 leading-none">{m.value}</span>
                      <span class="text-[8px] font-mono" style={{ color: m.color }}>{m.unit}</span>
                    </div>
                    <div class="text-[8px] dark:text-white/20 text-dark-300 mt-1 italic">{m.sublabel}</div>
                  </div>
                );
              })}
            </div>

            <!-- ── TDEE row ── -->
            <div
              class="rounded-xl p-3.5 mb-3"
              style={{ background: 'rgba(0,212,255,0.05)', border: '1px solid rgba(0,212,255,0.15)' }}
            >
              <div class="flex items-center justify-between mb-3">
                <span class="text-[10px] font-semibold dark:text-white/60 text-dark-500 flex items-center gap-1.5">
                  <TrendingUp class="w-3 h-3 text-neon-blue flex-none" />
                  Daily Calorie Need
                </span>
                <span class="font-display font-black text-sm text-neon-blue">2,618 kcal/day</span>
              </div>
              <div class="flex gap-2">
                {goalChips.map((chip) => (
                  <div
                    class="flex-1 text-center rounded-lg py-1.5 px-1 transition-all duration-200"
                    style={{
                      color: chip.color,
                      background: `${chip.color}${chip.active ? '22' : '0D'}`,
                      border: `1px solid ${chip.color}${chip.active ? '50' : '20'}`,
                      boxShadow: chip.active ? `0 0 10px ${chip.color}30` : 'none',
                      opacity: chip.active ? 1 : 0.6,
                    }}
                  >
                    <div class="text-[9px] font-black leading-tight">{chip.label}</div>
                    {chip.kcal && <div class="text-[8px] font-mono opacity-75 mt-0.5">{chip.kcal}</div>}
                  </div>
                ))}
              </div>
            </div>

            <!-- ── Doctor warning (shown at critical BMI extremes) ── -->
            <div class="flex items-center gap-2 px-3 py-2 rounded-lg opacity-40"
              style="background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2);">
              <span class="text-[9px]" style="color: #ef4444;">⚕</span>
              <p class="text-[9px] font-mono" style="color: rgba(239,68,68,0.8);">
                Doctor consultation recommended at critical BMI extremes (&lt;17.5 or &gt;35)
              </p>
            </div>
          </div>
        </div>

        <!-- ── RIGHT: Description + benefits ── -->
        <div class="reveal-right flex flex-col gap-6">
          <h3 class="font-display font-black text-3xl sm:text-4xl dark:text-white text-dark-950">
            Fitness tracking that<br/>
            <span class="gradient-text-lime">knows the science.</span>
          </h3>
          <p class="dark:text-white/60 text-dark-500 leading-relaxed">
            Every number in your Health Profile comes from a real clinical formula — not estimates.
            BMI, BMR, max heart rate, TDEE, ideal weight. It updates automatically as you move, run, and claim territory.
          </p>

          <div class="space-y-5">
            {benefits.map((b) => {
              const Icon = b.Icon;
              return (
                <div class="flex items-start gap-4 group">
                  <div
                    class="w-11 h-11 rounded-xl glass flex items-center justify-center flex-none transition-all duration-300 group-hover:scale-105"
                    style={{ color: b.color, boxShadow: `0 0 0 0 ${b.color}` }}
                  >
                    <Icon class="w-5 h-5" />
                  </div>
                  <div>
                    <h4 class="font-semibold dark:text-white text-dark-900 mb-1">{b.title}</h4>
                    <p class="text-sm dark:text-white/50 text-dark-500 leading-relaxed">{b.desc}</p>
                  </div>
                </div>
              );
            })}
          </div>

          <!-- Stats row -->
          <div class="grid grid-cols-3 gap-4 pt-6 border-t dark:border-white/10 border-dark-900/10">
            <div>
              <div class="font-display font-black text-3xl gradient-text-lime">73%</div>
              <div class="text-xs dark:text-white/40 text-dark-400 mt-1">More steps daily</div>
            </div>
            <div>
              <div class="font-display font-black text-3xl gradient-text-lime">2.4×</div>
              <div class="text-xs dark:text-white/40 text-dark-400 mt-1">More active days</div>
            </div>
            <div>
              <div class="font-display font-black text-3xl gradient-text-lime">94%</div>
              <div class="text-xs dark:text-white/40 text-dark-400 mt-1">Would recommend</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>