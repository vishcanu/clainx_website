---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/navigation/Navbar.astro';
import Footer from '../components/navigation/Footer.astro';
---

<BaseLayout
  title="Download"
  description="Get ClaimX on Android. Join the waitlist for the June 2026 beta — walk, run, or cycle to claim your city."
>
  <Navbar />
  <main>
    <!-- Hero download -->
    <section class="relative min-h-screen flex items-start pt-[22px] pb-8 overflow-hidden">
      <div class="absolute inset-0 dark:bg-dark-950 bg-light-50"></div>
      <div class="absolute inset-0 grid-overlay opacity-30"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] bg-neon-blue/6 rounded-full blur-[150px]"></div>

      <div class="relative section-padding w-full">
        <div class="section-container">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            
            <!-- Left: content -->
            <div>
              <span class="badge-blue mb-6 inline-block">
                <span class="w-1.5 h-1.5 rounded-full bg-neon-lime animate-pulse"></span>
                Beta Now Open
              </span>

              <h1 class="font-display font-black text-5xl sm:text-6xl lg:text-7xl dark:text-white text-dark-950 mb-6 leading-none tracking-tighter">
                Get ClaimX<br/>
                <span class="gradient-text">on Android.</span>
              </h1>

              <p class="dark:text-white/60 text-dark-500 text-xl leading-relaxed mb-10 max-w-lg">
                Android beta launching June 2026. Free forever. No pay-to-win.
                Walk, run, or cycle — every move builds your empire.
              </p>

              <!-- App store button -->
              <div class="flex flex-col sm:flex-row gap-4 mb-10">
                <a
                  href="#waitlist"
                  class="flex items-center gap-4 px-6 py-4 rounded-2xl dark:bg-white/5 bg-dark-900/5 border dark:border-white/10 border-dark-900/10 hover:border-neon-blue/30 hover:shadow-neon-blue transition-all duration-300 group"
                >
                  <svg class="w-8 h-8 dark:text-white/70 group-hover:text-neon-blue transition-colors" viewBox="0 0 24 24" fill="currentColor">
                    <path d="m3.18 23.76 9.19-9.19-2.17-2.17-7.02 11.36zm14.64-14.64L3.93 1.48A2 2 0 0 0 2 3.3v17.4a2 2 0 0 0 1.93 1.82l13.89-13.4zm-6.56 5.44-7.29 7.29L16.2 14.4l-4.94-4.84zm6.53-6.09-3.98 3.97 3.98 3.98a2 2 0 0 0 0-7.95z"/>
                  </svg>
                  <div>
                    <div class="text-xs dark:text-white/40 text-dark-400">Get it on</div>
                    <div class="font-display font-bold text-lg dark:text-white text-dark-900">Google Play</div>
                  </div>
                </a>
                <div class="flex items-center gap-3 px-6 py-4 rounded-2xl dark:bg-white/3 bg-dark-900/3 border dark:border-white/5 border-dark-900/5">
                  <div class="w-8 h-8 rounded-lg dark:bg-white/10 bg-dark-900/10 flex items-center justify-center">
                    <svg class="w-5 h-5 dark:text-white/30 text-dark-400" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                    </svg>
                  </div>
                  <div>
                    <div class="text-xs dark:text-white/30 text-dark-400">iOS</div>
                    <div class="text-sm dark:text-white/40 text-dark-500">Coming soon</div>
                  </div>
                </div>
              </div>

              <!-- QR Code section -->
              <div class="flex items-center gap-4 glass rounded-2xl p-4 max-w-sm">
                <!-- QR placeholder -->
                <div class="w-20 h-20 rounded-xl dark:bg-white/10 bg-dark-900/10 flex items-center justify-center flex-none">
                  <svg class="w-16 h-16 dark:text-white/20 text-dark-900/20" viewBox="0 0 100 100" fill="currentColor">
                    <!-- QR code visual placeholder -->
                    <rect x="10" y="10" width="30" height="30" rx="3" fill="currentColor"/>
                    <rect x="15" y="15" width="20" height="20" rx="2" fill="transparent" stroke="currentColor" stroke-width="4"/>
                    <rect x="60" y="10" width="30" height="30" rx="3" fill="currentColor"/>
                    <rect x="65" y="15" width="20" height="20" rx="2" fill="transparent" stroke="currentColor" stroke-width="4"/>
                    <rect x="10" y="60" width="30" height="30" rx="3" fill="currentColor"/>
                    <rect x="15" y="65" width="20" height="20" rx="2" fill="transparent" stroke="currentColor" stroke-width="4"/>
                    <rect x="60" y="60" width="10" height="10" rx="1" fill="currentColor"/>
                    <rect x="75" y="60" width="15" height="10" rx="1" fill="currentColor"/>
                    <rect x="60" y="75" width="15" height="10" rx="1" fill="currentColor"/>
                    <rect x="80" y="75" width="10" height="10" rx="1" fill="currentColor"/>
                    <rect x="45" y="10" width="10" height="10" rx="1" fill="currentColor"/>
                    <rect x="45" y="25" width="10" height="10" rx="1" fill="currentColor"/>
                    <rect x="10" y="45" width="10" height="10" rx="1" fill="currentColor"/>
                    <rect x="25" y="45" width="10" height="10" rx="1" fill="currentColor"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-sm dark:text-white text-dark-900 mb-1">Scan to Download</div>
                  <div class="text-xs dark:text-white/40 text-dark-400">Point your camera here for instant download link</div>
                </div>
              </div>
            </div>

            <!-- Right: Phone mockup -->
            <div class="flex justify-center lg:justify-end">
              <div class="relative">
                <!-- Phone frame -->
                <div class="relative w-[220px] sm:w-[260px]">
                  <!-- Glow behind phone -->
                  <div class="absolute inset-0 bg-neon-blue/20 rounded-[3rem] blur-3xl animate-pulse-glow"></div>
                  
                  <!-- Phone shell -->
                  <div class="relative rounded-[2.5rem] dark:bg-dark-800 bg-white border dark:border-white/10 border-dark-900/10 overflow-hidden shadow-2xl shadow-neon-blue/10" style="aspect-ratio: 9/18;">
                    <!-- Notch -->
                    <div class="absolute top-4 left-1/2 -translate-x-1/2 w-24 h-5 dark:bg-dark-900 bg-light-200 rounded-full z-10"></div>
                    
                    <!-- Screen content — real app screenshots -->
                    <div class="absolute inset-0 overflow-hidden bg-dark-950 flex items-center justify-center">
                      <img class="phone-slide phone-s1 absolute inset-0 w-full h-full object-contain" src="/mobile%20image/map-page.jpg" alt="Map" />
                      <img class="phone-slide phone-s2 absolute inset-0 w-full h-full object-contain" src="/mobile%20image/activity-page.jpg" alt="Activity" />
                      <img class="phone-slide phone-s3 absolute inset-0 w-full h-full object-contain" src="/mobile%20image/health-stat.jpg" alt="Health" />
                      <img class="phone-slide phone-s4 absolute inset-0 w-full h-full object-contain" src="/mobile%20image/power-page.jpg" alt="Power" />
                      <img class="phone-slide phone-s5 absolute inset-0 w-full h-full object-contain" src="/mobile%20image/share-teritory.png" alt="Share" />
                    </div>

                    <!-- Home indicator -->
                    <div class="absolute bottom-2 left-1/2 -translate-x-1/2 w-24 h-1 dark:bg-white/20 bg-dark-900/20 rounded-full"></div>
                  </div>

                  <!-- Floating UI badges -->
                  <div class="absolute -left-8 top-1/4 glass rounded-xl p-2.5 flex items-center gap-2 animate-float" style="animation-delay: -2s;">
                    <span class="text-xl">🏆</span>
                    <div>
                      <div class="text-[10px] dark:text-white/40 text-dark-400">Season Rank</div>
                      <div class="text-xs font-bold text-neon-orange">#3 Global</div>
                    </div>
                  </div>

                  <div class="absolute -right-8 top-2/3 glass rounded-xl p-2.5 flex items-center gap-2 animate-float" style="animation-delay: -5s;">
                    <span class="text-xl">⚡</span>
                    <div>
                      <div class="text-[10px] dark:text-white/40 text-dark-400">Siege Ready</div>
                      <div class="text-xs font-bold text-neon-blue">BLAZE</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Waitlist section -->
    <section id="waitlist" class="relative py-24 overflow-hidden dark:bg-dark-900 bg-light-100">
      <div class="absolute inset-0 grid-overlay opacity-20"></div>
      <div class="section-padding">
        <div class="section-container max-w-2xl mx-auto text-center">
          <span class="badge-lime mb-6 inline-block">
            <span class="w-1.5 h-1.5 rounded-full bg-neon-lime animate-pulse"></span>
            47,218 on waitlist
          </span>
          <h2 class="font-display font-black text-4xl sm:text-5xl dark:text-white text-dark-950 mt-4 mb-6">
            Join the Waitlist.<br/>
            <span class="gradient-text-lime">Lock In Your City.</span>
          </h2>
          <p class="dark:text-white/60 text-dark-500 mb-10 text-lg leading-relaxed">
            Early access. Founder badge. Territory head start. Reserved city placement. 
            Don't let your rivals claim your neighborhood first.
          </p>

          <!-- Waitlist form -->
          <form id="waitlist-form" class="flex flex-col sm:flex-row gap-3" novalidate>
            <div class="flex-1">
              <input
                type="email"
                id="waitlist-email"
                name="email"
                placeholder="your@email.com"
                autocomplete="email"
                class="w-full px-5 py-4 rounded-xl dark:bg-white/5 bg-white border dark:border-white/10 border-dark-900/15 dark:text-white text-dark-900 placeholder:dark:text-white/30 placeholder:text-dark-400 outline-none focus:border-neon-blue/50 focus:shadow-glow-sm transition-all duration-300 text-base"
                required
              />
            </div>
            <button
              type="submit"
              class="btn-primary px-8 py-4 text-base whitespace-nowrap"
            >
              Claim My Spot →
            </button>
          </form>

          <div id="waitlist-success" class="hidden mt-4 glass rounded-xl p-4 border-neon-lime/20">
            <div class="flex items-center gap-3">
              <span class="text-2xl">🎉</span>
              <div class="text-left">
                <div class="font-semibold dark:text-white text-dark-900">You're in!</div>
                <div class="text-sm dark:text-white/50 text-dark-500">We'll notify you the moment your city unlocks.</div>
              </div>
            </div>
          </div>

          <p class="dark:text-white/30 text-dark-400 text-sm mt-4">
            No spam. No credit card. Just early access.
          </p>

          <!-- Benefits list -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-12">
            {[
              { icon: '🌆', title: 'City Head Start', desc: 'Claim territory before the public launch' },
              { icon: '🏅', title: 'Founder Badge', desc: 'Exclusive in-game founder status forever' },
              { icon: '⚡', title: 'Bonus XP Pack', desc: '10,000 bonus XP on day one' },
            ].map((benefit) => (
              <div class="glass rounded-2xl p-4 text-center">
                <div class="text-3xl mb-2">{benefit.icon}</div>
                <div class="font-semibold text-sm dark:text-white text-dark-900 mb-1">{benefit.title}</div>
                <div class="text-xs dark:text-white/40 text-dark-400">{benefit.desc}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .phone-slide { opacity: 0; }
  .phone-s1 { animation: imgShow 15s ease-in-out infinite 0s; }
  .phone-s2 { animation: imgShow 15s ease-in-out infinite 3s; }
  .phone-s3 { animation: imgShow 15s ease-in-out infinite 6s; }
  .phone-s4 { animation: imgShow 15s ease-in-out infinite 9s; }
  .phone-s5 { animation: imgShow 15s ease-in-out infinite 12s; }
  @keyframes imgShow {
    0%   { opacity: 0; }
    2%   { opacity: 1; }
    18%  { opacity: 1; }
    20%  { opacity: 0; }
    100% { opacity: 0; }
  }
</style>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement;
  const successEl = document.getElementById('waitlist-success')!;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const emailInput = document.getElementById('waitlist-email') as HTMLInputElement;
    const email = emailInput.value.trim();
    
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      emailInput.style.borderColor = 'rgba(255,0,128,0.5)';
      return;
    }

    // Simulate successful submission
    form.style.display = 'none';
    successEl.classList.remove('hidden');
  });
</script>
