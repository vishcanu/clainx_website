---
import icons from '../../lib/icons';

// Navbar component - responsive, glass morphism, with theme toggle
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/features', label: 'Features' },
  { href: '/arena', label: 'Arena' },
  { href: '/about', label: 'About' },
  { href: '/download', label: 'Download' },
];

const currentPath = Astro.url.pathname;
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="section-padding">
    <nav class="max-w-7xl mx-auto flex items-center justify-between h-[72px]">
      
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group" aria-label="ClaimX Home">
        <div class="relative w-9 h-9">
          <div class="absolute inset-0 rounded-xl bg-gradient-to-br from-neon-blue to-neon-cyan opacity-20 group-hover:opacity-40 transition-opacity duration-300 blur-sm"></div>
          <div class="relative w-9 h-9 rounded-xl bg-dark-800 border border-neon-blue/20 flex items-center justify-center group-hover:border-neon-blue/50 transition-all duration-300">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="xLogoGrad" x1="2" y1="2" x2="22" y2="22" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#00D4FF"/>
                  <stop offset="1" stop-color="#00FFE7"/>
                </linearGradient>
              </defs>
              <path stroke="url(#xLogoGrad)" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.24 10.233A4.619 4.619 0 0 0 12 8.89c-1.204 0-2.39.492-3.24 1.344l-6.244 6.243c-1.32 1.38-1.296 3.63.054 4.981 1.351 1.35 3.602 1.375 4.981.054l4.45-4.449 4.448 4.45c1.38 1.32 3.63 1.296 4.98-.055 1.351-1.35 1.376-3.6.055-4.98l-6.243-6.244Z"/>
              <path stroke="url(#xLogoGrad)" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.993 12 2.516 7.524c-1.32-1.38-1.296-3.63.054-4.981 1.351-1.35 3.602-1.375 4.981-.054l4.45 4.449 4.448-4.45c1.38-1.32 3.63-1.296 4.98.055 1.351 1.35 1.376 3.6.055 4.98L17.007 12"/>
              <path stroke="url(#xLogoGrad)" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.007 12 12 17.064 6.993 12"/>
            </svg>
          </div>
        </div>
        <span class="font-display font-bold text-xl tracking-tight dark:text-white text-dark-900">
          Claim<span class="xheart">
            <!-- X layer -->
            <span class="xheart-x gradient-text">X</span>
            <!-- Heart icon (stroke-based, matches icon library style) -->
            <span class="xheart-heart" aria-hidden="true">
              <svg width="0.88em" height="0.88em" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <linearGradient id="heartNavGrad" x1="2" y1="4" x2="22" y2="20" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#FF0080"/>
                    <stop offset="1" stop-color="#FF6B00"/>
                  </linearGradient>
                </defs>
                <path
                  stroke="url(#heartNavGrad)"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
                />
              </svg>
            </span>
            <!-- Ripple ring that expands on burst -->
            <span class="xheart-ring" aria-hidden="true"></span>
          </span>
        </span>
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class={`px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300 underline-glow ${
                currentPath === link.href
                  ? 'text-neon-blue bg-neon-blue/5'
                  : 'dark:text-white/70 text-dark-600 hover:text-neon-blue dark:hover:text-neon-blue hover:bg-neon-blue/5'
              }`}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right actions -->
      <div class="flex items-center gap-3">
        <!-- Theme toggle -->
        <button
          id="theme-toggle"
          class="w-9 h-9 rounded-lg glass flex items-center justify-center transition-all duration-300 hover:border-neon-blue/40 hover:shadow-glow-sm"
          aria-label="Toggle theme"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg class="dark:block hidden w-4 h-4 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg class="dark:hidden block w-4 h-4 text-dark-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <!-- CTA -->
        <a href="/download" class="hidden sm:inline-flex btn-primary text-sm px-5 py-2.5 gap-2">
          <span class="w-4 h-4 block flex-none" set:html={icons.download}></span>
          Get App
        </a>

        <!-- Mobile menu toggle -->
        <button
          id="mobile-menu-btn"
          class="md:hidden w-9 h-9 rounded-lg glass flex items-center justify-center"
          aria-label="Open menu"
        >
          <div class="flex flex-col gap-1.5">
            <span class="mobile-line block w-5 h-0.5 bg-current rounded-full transition-all duration-300"></span>
            <span class="mobile-line block w-5 h-0.5 bg-current rounded-full transition-all duration-300"></span>
            <span class="mobile-line block w-3 h-0.5 bg-current rounded-full transition-all duration-300 ml-auto"></span>
          </div>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu drawer -->
  <div
    id="mobile-menu"
    class="md:hidden fixed inset-0 z-40 opacity-0 pointer-events-none transition-opacity duration-300"
    aria-hidden="true"
  >
    <!-- Theme-aware background (single class, no conflict) -->
    <div class="absolute inset-0 dark:bg-dark-950 bg-white backdrop-blur-2xl"></div>
    <!-- Subtle grid overlay -->
    <div class="absolute inset-0 grid-overlay opacity-20 pointer-events-none"></div>
    <!-- Accent glow -->
    <div class="absolute top-0 right-0 w-64 h-64 bg-neon-blue/8 rounded-full blur-3xl pointer-events-none"></div>

    <!-- Menu content -->
    <div class="relative h-full flex flex-col pt-20 pb-10 px-6 overflow-y-auto">

      <!-- Close button -->
      <button
        id="mobile-menu-close"
        class="absolute top-5 right-5 w-10 h-10 rounded-xl glass flex items-center justify-center dark:text-white/70 text-dark-600 hover:text-neon-blue transition-colors"
        aria-label="Close menu"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

      <!-- Nav links -->
      <nav class="flex-1">
        <ul class="flex flex-col divide-y dark:divide-white/5 divide-dark-900/8">
          {navLinks.map((link, i) => (
            <li style={`--delay: ${i * 60}ms`} class="mobile-nav-item opacity-0 translate-y-3 transition-all duration-400">
              <a
                href={link.href}
                class={`flex items-center justify-between py-5 text-2xl font-display font-black tracking-tight transition-colors duration-300 ${
                  currentPath === link.href
                    ? 'text-neon-blue'
                    : 'dark:text-white text-dark-900 hover:text-neon-blue'
                }`}
              >
                {link.label}
                <span class={`text-base font-mono transition-colors duration-300 ${
                  currentPath === link.href ? 'text-neon-blue' : 'dark:text-white/20 text-dark-300'
                }`}>→</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- CTA buttons -->
      <div class="mobile-nav-item opacity-0 translate-y-3 transition-all duration-400 mt-8 flex flex-col gap-3" style="--delay: 360ms">
        <a href="/download" class="btn-primary justify-center text-base py-4">
          Download App
        </a>
        <a href="/download#waitlist" class="btn-secondary justify-center text-base py-4">
          Join Waitlist
        </a>
      </div>

      <!-- Footer row -->
      <div class="mobile-nav-item opacity-0 translate-y-3 transition-all duration-400 mt-8 pt-6 border-t dark:border-white/8 border-dark-900/8" style="--delay: 420ms">
        <div class="flex items-center gap-5 mb-3">
          <a href="https://instagram.com/claimxapp" target="_blank" rel="noopener noreferrer" class="dark:text-white/35 text-dark-400 hover:text-neon-blue transition-colors text-sm">Instagram</a>
          <a href="https://linkedin.com/company/claimx" target="_blank" rel="noopener noreferrer" class="dark:text-white/35 text-dark-400 hover:text-neon-blue transition-colors text-sm">LinkedIn</a>
          <a href="https://youtube.com/@claimxapp" target="_blank" rel="noopener noreferrer" class="dark:text-white/35 text-dark-400 hover:text-neon-blue transition-colors text-sm">YouTube</a>
        </div>
        <p class="dark:text-white/20 text-dark-400 text-xs">© 2026 ClaimX, Inc.</p>
      </div>

    </div>
  </div>
</header>

<style>
  /* Stack all layers in the same grid cell */
  .xheart {
    display: inline-grid;
    place-items: center;
    vertical-align: baseline;
  }
  .xheart > * { grid-area: 1 / 1; }

  /* ── X layer ── */
  .xheart-x {
    display: inline-block;
    animation: xHeartOut 7s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes xHeartOut {
    0%, 20%   { opacity: 1; transform: scale(1);             filter: drop-shadow(0 0 5px rgba(0,212,255,0.55)); }
    /* Spin away */
    27%       { opacity: 0; transform: scale(0.05) rotate(25deg); filter: none; }
    28%, 57%  { opacity: 0; transform: scale(0); }
    /* Pop back in — 3 micro-bounces for premium feel */
    64%       { opacity: 1; transform: scale(1.55); filter: drop-shadow(0 0 20px rgba(0,255,231,1)); }
    69%       { opacity: 1; transform: scale(0.88); filter: drop-shadow(0 0 10px rgba(0,212,255,0.7)); }
    73%       { opacity: 1; transform: scale(1.1);  filter: drop-shadow(0 0 12px rgba(0,212,255,0.8)); }
    77%       { opacity: 1; transform: scale(0.97); filter: drop-shadow(0 0 7px rgba(0,212,255,0.6)); }
    82%, 100% { opacity: 1; transform: scale(1);    filter: drop-shadow(0 0 5px rgba(0,212,255,0.55)); }
  }

  /* ── Heart icon layer ── */
  .xheart-heart {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    animation: heartBurst 7s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes heartBurst {
    0%, 25%   { opacity: 0; transform: scale(0); }
    /* Draw in with overshoot */
    33%       { opacity: 1; transform: scale(1.18); filter: drop-shadow(0 0 8px rgba(255,0,128,0.6)); }
    37%       { opacity: 1; transform: scale(0.92); }
    41%       { opacity: 1; transform: scale(1);    filter: drop-shadow(0 0 5px rgba(255,0,128,0.4)); }
    /* Beat 1 */
    46%       { opacity: 1; transform: scale(1.28); filter: drop-shadow(0 0 14px rgba(255,0,128,0.95)); }
    50%       { opacity: 1; transform: scale(1);    filter: drop-shadow(0 0 5px rgba(255,0,128,0.4)); }
    /* Beat 2 — slightly softer */
    54%       { opacity: 1; transform: scale(1.16); filter: drop-shadow(0 0 10px rgba(255,107,0,0.85)); }
    57%       { opacity: 1; transform: scale(1);    filter: drop-shadow(0 0 5px rgba(255,107,0,0.4)); }
    /* Burst — rapid expand + fade */
    63%       { opacity: 0; transform: scale(2.8);  filter: none; }
    64%, 100% { opacity: 0; transform: scale(0); }
  }

  /* ── Ripple ring ── */
  .xheart-ring {
    display: block;
    width: 1em;
    height: 1em;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 0, 128, 0.7);
    animation: heartRipple 7s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes heartRipple {
    0%, 55%   { opacity: 0;   transform: scale(0.6); }
    /* Expand outward as heart bursts */
    62%       { opacity: 0.6; transform: scale(1.4); border-color: rgba(255,107,0,0.6); }
    68%       { opacity: 0;   transform: scale(2.6); border-color: rgba(255,107,0,0); }
    69%, 100% { opacity: 0;   transform: scale(0.6); }
  }
</style>

<!-- Spacer -->
<div class="h-[72px]"></div>

<script>
  // =========================================================
  // Navbar behavior
  // =========================================================
  const navbar = document.getElementById('navbar')!;
  const mobileMenuBtn = document.getElementById('mobile-menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const themeToggle = document.getElementById('theme-toggle')!;
  
  let menuOpen = false;
  let lastScroll = 0;

  // Scroll behavior - glass on scroll
  const handleScroll = () => {
    const scrollY = window.scrollY;
    
    if (scrollY > 20) {
      navbar.classList.add('glass', 'border-b');
      navbar.classList.add('dark:border-white/5', 'border-dark-900/10');
    } else {
      navbar.classList.remove('glass', 'border-b');
      navbar.classList.remove('dark:border-white/5', 'border-dark-900/10');
    }

    // Hide on scroll down, show on scroll up
    if (scrollY > lastScroll && scrollY > 200 && !menuOpen) {
      navbar.style.transform = 'translateY(-100%)';
    } else {
      navbar.style.transform = 'translateY(0)';
    }
    lastScroll = scrollY;
  };

  window.addEventListener('scroll', handleScroll, { passive: true });

  // Mobile menu toggle
  const openMenu = () => {
    menuOpen = true;
    mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
    mobileMenu.classList.add('opacity-100');
    mobileMenu.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    
    // Animate items in
    setTimeout(() => {
      document.querySelectorAll('.mobile-nav-item').forEach((item, i) => {
        setTimeout(() => {
          item.classList.remove('opacity-0', 'translate-y-3');
        }, i * 60);
      });
    }, 50);
  };

  const closeMenu = () => {
    menuOpen = false;
    mobileMenu.classList.add('opacity-0', 'pointer-events-none');
    mobileMenu.classList.remove('opacity-100');
    mobileMenu.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    
    document.querySelectorAll('.mobile-nav-item').forEach((item) => {
      item.classList.add('opacity-0', 'translate-y-3');
    });
  };

  mobileMenuBtn.addEventListener('click', () => {
    menuOpen ? closeMenu() : openMenu();
  });

  // Close button inside menu
  document.getElementById('mobile-menu-close')?.addEventListener('click', closeMenu);

  // Close menu on link click
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuOpen) closeMenu();
  });

  // Theme toggle
  themeToggle.addEventListener('click', () => {
    const html = document.documentElement;
    const isDark = html.classList.contains('dark');
    html.classList.toggle('dark', !isDark);
    html.classList.toggle('light', isDark);
    localStorage.setItem('theme', isDark ? 'light' : 'dark');
  });
</script>
