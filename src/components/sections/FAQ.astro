---
// FAQ Section with animated accordion
const faqs = [
  {
    q: 'How does territory claiming work?',
    a: 'When you run, walk, or cycle through a real-world area, your GPS trace covers hexagonal zones on the map. Once your activity path covers a zone, it becomes yours — shown in your color. The more you move, the more territory you claim.',
  },
  {
    q: 'Is ClaimX free to play?',
    a: 'Yes. ClaimX is completely free to download and play. All territory mechanics, siege powers, and health tracking are available for free. We believe fitness achievements should never be gated behind a paywall.',
  },
  {
    q: 'What counts as activity?',
    a: 'Running, jogging, walking, cycling, and even skating count. The app auto-detects your activity type using motion sensors and GPS speed. Indoor treadmill mode is also supported through manual activation.',
  },
  {
    q: 'Can rivals steal my territory?',
    a: 'Yes! That\'s the whole point. Rival players can move through your claimed zones and reclaim them. This is what makes ClaimX so addictive — you need to keep moving to defend your empire. Siege powers add an extra layer of strategic combat.',
  },
  {
    q: 'How is the IMPRINT tier system calculated?',
    a: 'Your IMPRINT tier is based on total territories owned, distance covered, activity streaks, and arena performance. It\'s a holistic fitness score that reflects your real-world commitment. No shortcuts.',
  },
  {
    q: 'Is ClaimX safe for all fitness levels?',
    a: 'Absolutely. Whether you\'re a beginner who walks 3km per day or an ultramarathon runner, ClaimX adapts to your level. Start at LOWKEY tier and progress naturally. There\'s no pressure to sprint — even leisurely strolls claim territory.',
  },
  {
    q: 'When is the full launch?',
    a: 'ClaimX Android beta launches in June 2026. Join the waitlist now to get early access and founder-tier benefits when the map goes live.',
  },
  {
    q: 'Does it work without phone signal?',
    a: 'GPS works without mobile data. Your activity is tracked offline and syncs when you reconnect. Map tiles are cached for offline use in your local area.',
  },
];
---

<section class="relative py-3 lg:py-4 overflow-hidden">
  <div class="absolute inset-0 dark:bg-dark-950 bg-light-50"></div>
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-neon-blue/4 rounded-full blur-[120px]"></div>

  <div class="relative section-padding">
    <div class="section-container max-w-4xl mx-auto">
      
      <!-- Header -->
      <div class="text-center mb-8 reveal">
        <span class="badge-blue mb-4">FAQ</span>
        <h2 class="font-display font-black text-4xl sm:text-5xl dark:text-white text-dark-950 mt-4 mb-6">
          Got Questions?<br/>
          <span class="gradient-text">We've Got Answers.</span>
        </h2>
      </div>

      <!-- Accordion -->
      <div class="space-y-3 stagger-children reveal" id="faq-list">
        {faqs.map((faq, i) => (
          <div
            class="faq-item glass rounded-2xl overflow-hidden cursor-pointer group"
            data-index={i}
          >
            <!-- Question -->
            <button
              class="faq-trigger w-full text-left flex items-center justify-between p-5 sm:p-6 gap-4"
              aria-expanded="false"
            >
              <span class="font-semibold dark:text-white text-dark-900 text-sm sm:text-base leading-snug">
                {faq.q}
              </span>
              <div class="faq-icon flex-none w-8 h-8 rounded-lg glass flex items-center justify-center transition-all duration-300">
                <svg class="w-4 h-4 text-neon-blue transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path d="M12 5v14M5 12h14" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </div>
            </button>

            <!-- Answer -->
            <div class="faq-answer max-h-0 overflow-hidden transition-all duration-400">
              <div class="px-5 sm:px-6 pb-5 sm:pb-6">
                <div class="h-px dark:bg-white/5 bg-dark-900/10 mb-4"></div>
                <p class="dark:text-white/60 text-dark-500 text-sm leading-relaxed">{faq.a}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Bottom CTA -->
      <div class="text-center mt-12 reveal">
        <p class="dark:text-white/40 text-dark-400 mb-4">Still have questions?</p>
        <a href="mailto:hello@claimx.app" class="btn-secondary px-6 py-3">
          Contact Support →
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const faqItems = document.querySelectorAll('.faq-item');

  faqItems.forEach((item) => {
    const trigger = item.querySelector('.faq-trigger') as HTMLButtonElement;
    const answer = item.querySelector('.faq-answer') as HTMLElement;
    const icon = item.querySelector('.faq-icon svg') as SVGElement;

    trigger.addEventListener('click', () => {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Close all others
      faqItems.forEach((other) => {
        if (other !== item) {
          const otherTrigger = other.querySelector('.faq-trigger') as HTMLButtonElement;
          const otherAnswer = other.querySelector('.faq-answer') as HTMLElement;
          const otherIcon = other.querySelector('.faq-icon svg') as SVGElement;
          otherTrigger.setAttribute('aria-expanded', 'false');
          otherAnswer.style.maxHeight = '0';
          if (otherIcon) otherIcon.style.transform = 'rotate(0deg)';
          other.classList.remove('dark:border-neon-blue/20');
        }
      });

      // Toggle current
      if (isOpen) {
        trigger.setAttribute('aria-expanded', 'false');
        answer.style.maxHeight = '0';
        icon.style.transform = 'rotate(0deg)';
        item.classList.remove('dark:border-neon-blue/20', 'border-neon-blue/20');
      } else {
        trigger.setAttribute('aria-expanded', 'true');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        icon.style.transform = 'rotate(45deg)';
        item.classList.add('dark:border-neon-blue/20', 'border-neon-blue/20');
      }
    });
  });
</script>
