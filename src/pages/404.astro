---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/navigation/Navbar.astro';
import Footer from '../components/navigation/Footer.astro';
---

<BaseLayout title="404 — Territory Not Found" noIndex={true}>
  <Navbar />
  <main class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 dark:bg-dark-950 bg-light-50"></div>
    <div class="absolute inset-0 grid-overlay opacity-30"></div>
    
    <!-- Glow orbs -->
    <div class="absolute top-1/4 left-1/3 w-[400px] h-[400px] bg-neon-blue/6 rounded-full blur-[100px] animate-orb-float"></div>
    <div class="absolute bottom-1/4 right-1/3 w-[300px] h-[300px] bg-neon-purple/6 rounded-full blur-[80px] animate-orb-float" style="animation-delay: -6s;"></div>

    <!-- Animated radar in background -->
    <div class="absolute inset-0 flex items-center justify-center opacity-10">
      <div class="relative w-[600px] h-[600px]">
        {[100, 200, 300].map((r) => (
          <div
            key={r}
            class="absolute top-1/2 left-1/2 rounded-full border border-neon-blue/40"
            style={`width: ${r * 2}px; height: ${r * 2}px; transform: translate(-50%, -50%);`}
          ></div>
        ))}
        <!-- Radar sweep -->
        <div
          class="absolute top-1/2 left-1/2 w-[300px] h-[2px] origin-left"
          style="transform: translate(0, -50%);"
        >
          <div class="w-full h-full bg-gradient-to-r from-neon-blue/80 to-transparent animate-spin-slow"></div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="relative z-10 section-padding text-center max-w-3xl mx-auto">
      
      <!-- Animated 404 display -->
      <div class="mb-8">
        <div class="font-display font-black text-[160px] sm:text-[200px] lg:text-[240px] leading-none tracking-tighter select-none" style="color: transparent; -webkit-text-stroke: 2px rgba(0,212,255,0.15);">
          404
        </div>
        <div class="font-display font-black text-5xl sm:text-6xl lg:text-7xl gradient-text -mt-16 sm:-mt-20 relative z-10">
          404
        </div>
      </div>

      <!-- GPS scan animation -->
      <div class="flex items-center justify-center gap-3 mb-8">
        <div class="flex items-center gap-2 glass px-4 py-2 rounded-full">
          <div class="relative w-3 h-3">
            <div class="absolute inset-0 rounded-full bg-neon-orange animate-ping opacity-75"></div>
            <div class="relative w-3 h-3 rounded-full bg-neon-orange"></div>
          </div>
          <span class="font-mono text-sm text-neon-orange">GPS SCAN FAILED</span>
        </div>
      </div>

      <h1 class="font-display font-black text-3xl sm:text-4xl dark:text-white text-dark-950 mb-4">
        Territory Not Found.
      </h1>
      
      <p class="dark:text-white/60 text-dark-500 text-lg leading-relaxed mb-10 max-w-md mx-auto">
        This zone hasn't been claimed yet. Or maybe someone just sieged it into oblivion. 
        Either way, there's nothing here.
      </p>

      <!-- Action buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a href="/" class="btn-primary text-base px-8 py-4 gap-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <polyline points="9 22 9 12 15 12 15 22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Return to Base
        </a>
        <a href="/download" class="btn-secondary text-base px-8 py-4">
          Claim Territory →
        </a>
      </div>

      <!-- Navigation links -->
      <div class="flex flex-wrap gap-4 justify-center text-sm">
        {[
          { label: 'Home', href: '/' },
          { label: 'Features', href: '/features' },
          { label: 'Arena', href: '/arena' },
          { label: 'About', href: '/about' },
          { label: 'Download', href: '/download' },
        ].map((link) => (
          <a
            href={link.href}
            class="dark:text-white/40 text-dark-400 hover:text-neon-blue transition-colors duration-300 underline-glow"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
