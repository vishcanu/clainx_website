---
import icons from '../../lib/icons';
---

<section class="relative py-3 lg:py-4 overflow-hidden">
  <!-- Background layers -->
  <div class="absolute inset-0 dark:bg-dark-950 bg-light-50"></div>
  
  <!-- Animated city skyline effect -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <!-- Grid -->
    <div class="absolute inset-0 grid-overlay opacity-30"></div>
    
    <!-- Multi-layer glow orbs -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[600px] bg-neon-blue/8 rounded-full blur-[150px] animate-orb-float"></div>
    <div class="absolute top-1/3 left-1/3 w-[400px] h-[400px] bg-neon-purple/6 rounded-full blur-[100px] animate-orb-float" style="animation-delay: -5s;"></div>
    <div class="absolute bottom-1/3 right-1/3 w-[300px] h-[300px] bg-neon-cyan/5 rounded-full blur-[80px] animate-orb-float" style="animation-delay: -10s;"></div>

    <!-- Cityscape silhouette SVG -->
    <svg class="absolute bottom-0 left-0 right-0 w-full opacity-10" viewBox="0 0 1440 320" preserveAspectRatio="none" fill="none">
      <path d="M0 320V240l40-40V160l20-20V100l40-40V60L120 40V0h20v40l20 20V80l60-20V40h20v40l40 20v80l20 20V240H40v80zm240 0V200l40-40V140l30-30V80l40-40V0h20v80l30 40v40l40 20v120l40 40V320zm400 0V220l60-60V100l20-20V40h20v40l40 40v80l60 60V320zm300 0V240l40-20V180l20-20V120l50-50V40h20v80l40 40v60l40 20V320z" fill="url(#cityGrad)"/>
      <defs>
        <linearGradient id="cityGrad" x1="0" y1="0" x2="0" y2="1" gradientUnits="objectBoundingBox">
          <stop stop-color="#00D4FF" offset="0"/>
          <stop stop-color="#8B5CF6" offset="0.5"/>
          <stop stop-color="transparent" offset="1"/>
        </linearGradient>
      </defs>
    </svg>

    <!-- GPS path lines -->
    <svg class="absolute inset-0 w-full h-full opacity-20" viewBox="0 0 1440 800" preserveAspectRatio="none">
      <path d="M0 400 Q200 300 400 350 T800 300 T1200 380 T1440 320" stroke="url(#pathGrad1)" stroke-width="1.5" fill="none" stroke-dasharray="8 4">
        <animate attributeName="stroke-dashoffset" values="0;-120" dur="3s" repeatCount="indefinite"/>
      </path>
      <path d="M0 500 Q300 420 600 460 T1100 420 T1440 480" stroke="url(#pathGrad2)" stroke-width="1" fill="none" stroke-dasharray="6 4">
        <animate attributeName="stroke-dashoffset" values="0;-100" dur="4s" repeatCount="indefinite"/>
      </path>
      <defs>
        <linearGradient id="pathGrad1" gradientUnits="userSpaceOnUse" x1="0" y1="0" x2="1440" y2="0">
          <stop stop-color="#00D4FF" offset="0"/>
          <stop stop-color="#8B5CF6" offset="0.5"/>
          <stop stop-color="#00FFE7" offset="1"/>
        </linearGradient>
        <linearGradient id="pathGrad2" gradientUnits="userSpaceOnUse" x1="0" y1="0" x2="1440" y2="0">
          <stop stop-color="#FF6B00" offset="0"/>
          <stop stop-color="#FF0080" offset="1"/>
        </linearGradient>
      </defs>
    </svg>
  </div>

  <div class="relative z-10 section-padding">
    <div class="section-container text-center">
      
      <!-- Tagline -->
      <div class="reveal mb-6">
        <span class="badge-blue">
          <span class="w-1.5 h-1.5 rounded-full bg-neon-lime animate-pulse"></span>
          Health as a Game. Life as a Victory.
        </span>
      </div>

      <!-- Massive headline -->
      <div class="reveal mb-8" style="transition-delay: 0.1s;">
        <h2 class="font-display font-black leading-none tracking-tighter dark:text-white text-dark-950">
          <span class="block text-5xl sm:text-7xl lg:text-8xl xl:text-9xl mb-4">Your City</span>
          <span class="block text-5xl sm:text-7xl lg:text-8xl xl:text-9xl gradient-text text-glow-blue">Is Waiting.</span>
        </h2>
      </div>

      <!-- Subtext -->
      <p class="reveal dark:text-white/60 text-dark-500 text-xl sm:text-2xl max-w-2xl mx-auto mb-12 leading-relaxed" style="transition-delay: 0.2s;">
        Walk, run, or cycle to conquer your city.<br/>
        <span class="dark:text-white/90 text-dark-900 font-semibold">Your empire starts here.</span>
      </p>

      <!-- CTA buttons -->
      <div class="reveal flex flex-col sm:flex-row gap-4 justify-center mb-12" style="transition-delay: 0.3s;">
        <a href="/download#waitlist" class="btn-fire text-lg px-12 py-5 gap-3">
          <span class="w-5 h-5 flex-none" set:html={icons.android}></span>
          Join Waitlist — Android Beta
        </a>
        <a href="/features" class="btn-secondary text-lg px-12 py-5 gap-2">
          Explore Features
          <span class="w-4 h-4 flex-none" set:html={icons.arrowRight}></span>
        </a>
      </div>

      <!-- Trust signals -->
      <div class="reveal mt-12 flex flex-wrap items-center justify-center gap-6" style="transition-delay: 0.5s;">
        <div class="flex items-center gap-2 dark:text-white/30 text-dark-400 text-sm">
          <svg class="w-4 h-4 text-neon-lime" fill="currentColor" viewBox="0 0 24 24">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
          </svg>
          Free to Play
        </div>
        <div class="w-px h-4 dark:bg-white/10 bg-dark-900/10"></div>
        <div class="flex items-center gap-2 dark:text-white/30 text-dark-400 text-sm">
          <svg class="w-4 h-4 text-neon-lime" fill="currentColor" viewBox="0 0 24 24">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
          </svg>
          No Pay-to-Win
        </div>
        <div class="w-px h-4 dark:bg-white/10 bg-dark-900/10"></div>
        <div class="flex items-center gap-2 dark:text-white/30 text-dark-400 text-sm">
          <svg class="w-4 h-4 text-neon-lime" fill="currentColor" viewBox="0 0 24 24">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
          </svg>
          Android only &middot; Free to play &middot; No pay-to-win
        </div>
        <div class="w-px h-4 dark:bg-white/10 bg-dark-900/10"></div>
        <div class="flex items-center gap-2 dark:text-white/30 text-dark-400 text-sm">
          <svg class="w-4 h-4 text-neon-lime" fill="currentColor" viewBox="0 0 24 24">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
          </svg>
          Privacy First
        </div>
      </div>
    </div>
  </div>
</section>
